# Rail-Flow AI — Environment configuration template
# Copy to .env and fill in real values before running the server.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL is the production target.
# For local development without PostgreSQL set DEMO_MODE=true and run:
#   flask db upgrade   (or let DEMO_MODE=true auto-create on first run)
DATABASE_URL=postgresql+psycopg://railflow:railflow@localhost:5432/railflow_db

# ── Demo / development mode ───────────────────────────────────────────────────
# true  → db.create_all() on startup, deterministic fixtures, no random values
# false → requires `flask db upgrade` to have been run; no fixture auto-load
DEMO_MODE=true

# ── Delay trigger thresholds (minutes) ───────────────────────────────────────
DELAY_TRIGGER_MIN=5
PREDICTED_DELAY_TRIGGER_MIN=8

# ── Rolling-horizon parameters ────────────────────────────────────────────────
HORIZON_MIN=60
COMMIT_WINDOW_MIN=10
ROLLING_REFRESH_SECONDS=60

# ── Impact-zone caps ──────────────────────────────────────────────────────────
MAX_IMPACTED_TRAINS=80
MAX_IMPACTED_STATIONS=120

# ── Headway pruning heuristic ─────────────────────────────────────────────────
# Tune this on your dataset; do not treat 20 min as a universal railway law.
TRAIN_INTERACTION_HEADWAY_CUTOFF_MIN=20

# ── Predictor and policy selection ───────────────────────────────────────────
# auto          → use SAGE-Het if artifact exists, else historical_baseline
# historical_baseline → always use rule-based predictor
PREDICTOR_BACKEND=auto

# beam_search   → deterministic beam search (required for Phase 0–3)
# greedy        → greedy conflict resolution
POLICY_BACKEND=beam_search

# ── Beam-search / solver parameters ──────────────────────────────────────────
BEAM_WIDTH=8
MAX_POLICY_EXPANSIONS=500
POLICY_TIME_LIMIT_MS=1000
LOCAL_SEARCH_TIME_LIMIT_MS=1000

# ── Scenario / uncertainty parameters ────────────────────────────────────────
SCENARIO_COUNT=16
RISK_ALPHA=0.90
RISK_WEIGHT=0.25

# ── Feature flags (disabled until Phase 6+) ──────────────────────────────────
ENABLE_LOCAL_REROUTE=false
ENABLE_CANCELLATION=false
